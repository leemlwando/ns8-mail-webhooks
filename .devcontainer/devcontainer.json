// For format details, see https://aka.ms/devcontainer.json. For config options, see the README at:
// https://github.com/microsoft/vscode-dev-containers/tree/v0.245.2/containers/javascript-node
{
  "name": "ns8-mail-webhooks",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22-bookworm",

  // Features to add to the container
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "nodeGypDependencies": true,
      "version": "22"
    }
  },

  // Podman-specific run arguments (removed problematic Wayland mount)
  "runArgs": [
    "--userns=keep-id",
    "--network=host"
  ],
  // Simplified mounts that work with Podman on Windows
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind"
  ],

  // User configuration
  "containerUser": "node",
  "remoteUser": "node",
  "workspaceFolder": "/workspace",

  // Post-create setup
  "postCreateCommand": "cd /workspace/ui && npm install",

  // Configure tool-specific properties
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "octref.vetur", 
        "shenjiaolong.vue-helper",
        "waderyan.gitblame",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
