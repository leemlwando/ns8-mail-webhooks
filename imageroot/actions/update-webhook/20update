import json
import sys
import os
import subprocess

def get_webhook_server_url():
    """Get the webhook server URL from environment or default"""
    return os.getenv("WEBHOOK_SERVER_URL", "http://127.0.0.1:8080")

def update_webhook(webhook_id, data):
    """Update an existing webhook via the webhook server"""
    try:
        webhook_server_url = get_webhook_server_url()
        
        # Use curl to make the request
        cmd = [
            'curl', '-X', 'PUT',
            f'{webhook_server_url}/api/v1/webhooks/{webhook_id}',
            '-H', 'Content-Type: application/json',
            '-d', json.dumps(data),
            '--connect-timeout', '10'
        ]
        
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
        
        if result.returncode == 0:
            response_data = json.loads(result.stdout)
            return response_data
        else:
            raise Exception(f"HTTP request failed: {result.stderr}")
    except Exception as ex:
        raise Exception(f"Error updating webhook: {ex}")

try:
    request = json.load(sys.stdin)
    
    # Validate required fields
    if 'id' not in request:
        print("Missing required field: id", file=sys.stderr)
        sys.exit(1)
    
    webhook_id = request['id']
    
    # Update the webhook
    webhook_data = {}
    if 'name' in request:
        webhook_data['name'] = request['name']
    if 'url' in request:
        webhook_data['url'] = request['url']
    if 'mailbox' in request:
        webhook_data['mailbox'] = request['mailbox']
    if 'trigger_type' in request:
        webhook_data['trigger_type'] = request['trigger_type']
    if 'enabled' in request:
        webhook_data['enabled'] = request['enabled']
    if 'auth_token' in request:
        webhook_data['auth_token'] = request['auth_token']
    if 'custom_headers' in request:
        webhook_data['custom_headers'] = request['custom_headers']
    if 'filters' in request:
        webhook_data['filters'] = request['filters']
    
    result = update_webhook(webhook_id, webhook_data)
    json.dump(result, fp=sys.stdout)
    
except Exception as ex:
    print(f"Error: {ex}", file=sys.stderr)
    sys.exit(1)
