import sys
import os

# Ensure we can import agent module
try:
    import agent
except ImportError as e:
    print(f"Error importing agent module: {e}", file=sys.stderr)
    print(f"Python path: {sys.path}", file=sys.stderr)
    print(f"Current working directory: {os.getcwd()}", file=sys.stderr)
    sys.exit(1)

try:
    # Minimal grants as in kickstart
    agent.run_helper("redis-exec", "SADD", f"{agent.get_agent_uid()}/roles/reader", "get-*").check_returncode()
    agent.run_helper("redis-exec", "SADD", f"{agent.get_agent_uid()}/roles/selfadm", "configure-module", "get-configuration").check_returncode()
    sys.exit(0)
except Exception as e:
    print(f"Error setting up grants: {e}", file=sys.stderr)
    sys.exit(1)
