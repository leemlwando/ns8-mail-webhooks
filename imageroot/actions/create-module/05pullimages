import os
import sys
import json
import agent

# Read input data from stdin
try:
    data = json.load(sys.stdin)
    images = data.get('images', [])
except:
    images = []

print(f"Received images to pull: {images}", file=sys.stderr)

# This module uses external MongoDB (not self-hosted) and builds backend image locally
# No external images need to be pulled
if images:
    print(f"External images specified: {images}", file=sys.stderr)
    try:
        agent.run_helper('podman-pull-missing', *images).check_returncode()
        print("Successfully pulled external images", file=sys.stderr)
    except Exception as ex:
        print(f"Error pulling external images: {ex}", file=sys.stderr)
        sys.exit(1)
else:
    print("No external images to pull - backend will be built locally", file=sys.stderr)

print("Image pulling completed successfully", file=sys.stderr)
