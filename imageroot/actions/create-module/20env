import sys
import os

# Ensure we can import agent module
try:
    import agent
except ImportError as e:
    print(f"Error importing agent module: {e}", file=sys.stderr)
    print(f"Python path: {sys.path}", file=sys.stderr)
    print(f"Current working directory: {os.getcwd()}", file=sys.stderr)
    sys.exit(1)

try:
    # Set default environment variables for the mail webhooks module
    agent.set_env('MONGODB_URL', '')
    agent.set_env('WEBHOOKS_COLLECTION', 'webhooks')
    agent.set_env('EVENTS_COLLECTION', 'events')
    agent.set_env('SETTINGS_COLLECTION', 'settings')
    agent.set_env('TRIGGERS_COLLECTION', 'triggers')
    agent.set_env('LOGS_COLLECTION', 'logs')

    # HTTP/HTTPS settings
    agent.set_env('TRAEFIK_HOST', '')
    agent.set_env('TRAEFIK_HTTP2HTTPS', 'True')
    agent.set_env('TRAEFIK_LETS_ENCRYPT', 'False')

    # Mail server integration
    agent.set_env('MAIL_SERVER_UUID', '')

    # Backend image for the API service
    agent.set_env('BACKEND_IMAGE', 'ghcr.io/nethserver/mail-webhooks-backend:latest')    # Phase 1: API-only mode (no mail monitor)
    agent.set_env('MAIL_MONITOR_ENABLED', 'False')

    # Make sure everything is saved inside the environment file
    agent.dump_env()
    
    print("Environment variables set successfully", file=sys.stderr)
    sys.exit(0)  # Explicit success exit

except Exception as e:
    print(f"Error setting environment variables: {e}", file=sys.stderr)
    sys.exit(1)
