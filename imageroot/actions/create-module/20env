import sys
import os

# Ensure we can import agent module
try:
    import agent
except ImportError as e:
    print(f"Error importing agent module: {e}", file=sys.stderr)
    print(f"Python path: {sys.path}", file=sys.stderr)
    print(f"Current working directory: {os.getcwd()}", file=sys.stderr)
    sys.exit(1)

try:
    # Minimal env as in kickstart
    agent.set_env('MONGODB_URL', '')
    agent.set_env('TRAEFIK_HOST', '')
    # agent.dump_env() is deprecated and no longer needed
    sys.exit(0)
except Exception as e:
    print(f"Error setting environment variables: {e}", file=sys.stderr)
    sys.exit(1)
