set -e
exec 1>&2

# Fix permissions on all action scripts that might not be executable
echo "Fixing action script permissions..."

# Fix all action scripts
find "${AGENT_INSTALL_DIR}/actions" -type f -name "[0-9]*" -exec chmod +x {} \; 2>/dev/null || true

# Fix bin scripts if they exist
if [ -d "${AGENT_INSTALL_DIR}/bin" ]; then
    find "${AGENT_INSTALL_DIR}/bin" -type f -exec chmod +x {} \; 2>/dev/null || true
fi

# Fix any shell scripts
find "${AGENT_INSTALL_DIR}" -name "*.sh" -type f -exec chmod +x {} \; 2>/dev/null || true

echo "Permission fix completed successfully"
