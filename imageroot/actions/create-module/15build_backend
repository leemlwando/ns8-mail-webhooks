set -e
exec 1>&2

echo "Building backend image locally..."

# Set the backend image name 
BACKEND_IMAGE="${MAIL_WEBHOOKS_BACKEND_IMAGE:-ghcr.io/leemlwando/mail-webhooks-backend:latest}"
export MAIL_WEBHOOKS_BACKEND_IMAGE="${BACKEND_IMAGE}"

echo "Building backend image: ${BACKEND_IMAGE}"

# Build the backend image using the Containerfile in the api directory
cd /imageroot/api

# Build the image
if podman build -t "${BACKEND_IMAGE}" .; then
    echo "Successfully built backend image: ${BACKEND_IMAGE}"
else
    echo "Error: Failed to build backend image"
    exit 1
fi

# Verify the image was created
if podman image exists "${BACKEND_IMAGE}"; then
    echo "Backend image verified: ${BACKEND_IMAGE}"
else
    echo "Error: Backend image was not created properly"
    exit 1
fi
