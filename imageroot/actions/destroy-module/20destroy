# Remove traefik route

import os
import sys
import json
import agent
import agent.tasks

try:
    data = json.load(sys.stdin)
    traefik_id = agent.resolve_agent_id('traefik@node')
    if traefik_id:
        agent.tasks.run(
            agent_id=traefik_id,
            action='delete-route',
            data={'instance': os.environ['MODULE_ID']}
        )
    sys.exit(0)
except Exception as e:
    print(f"Warning: Error removing traefik route: {e}", file=sys.stderr)
    sys.exit(0)
