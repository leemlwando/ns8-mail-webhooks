import json
import sys
import os
import agent

# Read current configuration from environment
config = {
    "mongodb_url": os.getenv("MONGODB_URL", ""),
    "mail_server_uuid": os.getenv("MAIL_SERVER_UUID", ""),
    "http2https": os.getenv("TRAEFIK_HTTP2HTTPS", "False") == "True",
    "lets_encrypt": os.getenv("TRAEFIK_LETS_ENCRYPT", "False") == "True",
}

# Get available mail servers from service discovery
rdb = agent.redis_connect()
mail_servers = []

try:
    # Find all mail server instances
    for provider in agent.list_service_providers(rdb, 'imap', 'tcp'):
        mail_servers.append({
            "uuid": provider['module_uuid'],
            "module_id": provider['module_id'],
            "host": provider['host'],
            "user_domain": provider.get('user_domain', ''),
        })
except Exception as e:
    print(f"Warning: Could not retrieve mail servers: {e}", file=sys.stderr)

config["available_mail_servers"] = mail_servers

# Output configuration as JSON
json.dump(config, fp=sys.stdout, indent=2)
