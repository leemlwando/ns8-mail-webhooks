{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "get-configuration output",
    "$id": "http://schema.nethserver.org/mail-webhooks/get-configuration-output.json",
    "description": "Get Mail Webhooks configuration",
    "examples": [
        {
            "mongodb_url": "mongodb://localhost:27017/mailwebhooks",
            "webhooks_collection": "webhooks",
            "jobs_collection": "jobs",
            "logs_collection": "logs"
        }
    ],
    "type": "object",
    "properties": {
        "mongodb_url": {
            "type": "string",
            "title": "MongoDB connection URL"
        },
        "webhooks_collection": {
            "type": "string",
            "title": "Webhooks collection name"
        },
        "jobs_collection": {
            "type": "string",
            "title": "Jobs collection name"
        },
        "logs_collection": {
            "type": "string", 
            "title": "Logs collection name"
        }
    }
}