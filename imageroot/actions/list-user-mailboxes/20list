import json
import sys
import os

# Add pypkg to Python path
sys.path.insert(0, os.path.join(os.environ['AGENT_INSTALL_DIR'], 'pypkg'))

from mailwebhook.imap_client import SimpleIMAPClient

def main():
    try:
        # Get IMAP credentials from environment
        imap_user = os.getenv('MAIL_ADMIN_USER', 'admin')
        imap_pass = os.getenv('MAIL_ADMIN_PASS', '')
        
        if not imap_pass:
            # Fallback: try to get from mail module
            # This would typically be configured during module setup
            json.dump({
                "mailboxes": [
                    {"address": "admin@example.com", "name": "Administrator"},
                    {"address": "support@example.com", "name": "Support"},
                ]
            }, sys.stdout)
            return
        
        # Connect to IMAP and list mailboxes
        imap = SimpleIMAPClient()
        
        if imap.connect(imap_user, imap_pass):
            mailboxes = imap.list_mailboxes()
            imap.disconnect()
            
            # Format for frontend
            formatted_mailboxes = []
            for mb in mailboxes:
                formatted_mailboxes.append({
                    "address": mb,
                    "name": mb
                })
            
            json.dump({"mailboxes": formatted_mailboxes}, sys.stdout)
        else:
            # Fallback to empty list if connection fails
            json.dump({"mailboxes": []}, sys.stdout)
            
    except Exception as e:
        # Return empty list on error
        json.dump({"mailboxes": []}, sys.stdout)

if __name__ == "__main__":
    main()
