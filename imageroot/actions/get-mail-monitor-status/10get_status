# Get mail monitor status

set -e

# Check if service is running
if systemctl --user is-active --quiet mail-monitor.service; then
    STATUS="running"
    ENABLED=$(systemctl --user is-enabled mail-monitor.service 2>/dev/null || echo "disabled")
else
    STATUS="stopped"
    ENABLED="disabled"
fi

# Get last few log entries
LOGS=$(journalctl --user -u mail-monitor.service --no-pager -n 10 --output=json-pretty 2>/dev/null || echo "[]")

# Output status in JSON format
jq -n \
    --arg status "$STATUS" \
    --arg enabled "$ENABLED" \
    --argjson logs "$LOGS" \
    '{
        "status": $status,
        "enabled": $enabled,
        "logs": $logs,
        "service_name": "mail-monitor.service"
    }'
