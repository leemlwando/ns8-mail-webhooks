import json
import sys
import os
import subprocess

def get_webhook_server_url():
    """Get the webhook server URL from environment or default"""
    return os.getenv("WEBHOOK_SERVER_URL", "http://127.0.0.1:8080")

def get_webhook_logs():
    """Get webhook execution logs from the webhook server"""
    try:
        webhook_server_url = get_webhook_server_url()
        
        # Use curl to make the request
        cmd = [
            'curl', '-X', 'GET',
            f'{webhook_server_url}/api/v1/logs',
            '--connect-timeout', '10'
        ]
        
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
        
        if result.returncode == 0:
            response_data = json.loads(result.stdout)
            # Transform the data to match NS8 UI expectations
            logs = []
            for log_entry in response_data.get('logs', []):
                logs.append({
                    'id': log_entry.get('id'),
                    'webhook_id': log_entry.get('webhook_id'),
                    'webhook_name': log_entry.get('webhook_name'),
                    'timestamp': log_entry.get('timestamp'),
                    'status': log_entry.get('status'),
                    'response_code': log_entry.get('response_code'),
                    'error_message': log_entry.get('error_message'),
                    'execution_time': log_entry.get('execution_time'),
                    'email_subject': log_entry.get('email_subject'),
                    'email_from': log_entry.get('email_from')
                })
            return logs
        else:
            raise Exception(f"HTTP request failed: {result.stderr}")
    except Exception as ex:
        print(f"Error fetching logs: {ex}", file=sys.stderr)
        return []

try:
    logs = get_webhook_logs()
    json.dump(logs, fp=sys.stdout)
except Exception as ex:
    print(f"Error: {ex}", file=sys.stderr)
    sys.exit(1)
