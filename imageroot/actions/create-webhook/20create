import json
import sys
import os
import requests
from requests.adapters import HTTPAdapter
from urllib3.util.retry import Retry

try:
    import agent
except ImportError as e:
    print(f"Error importing agent module: {e}", file=sys.stderr)
    sys.exit(1)

def make_request(method, url, **kwargs):
    """Make HTTP request with retry logic"""
    session = requests.Session()
    retry_strategy = Retry(
        total=3,
        backoff_factor=1,
        status_forcelist=[429, 500, 502, 503, 504],
    )
    adapter = HTTPAdapter(max_retries=retry_strategy)
    session.mount("http://", adapter)
    session.mount("https://", adapter)
    
    try:
        response = session.request(method, url, timeout=30, **kwargs)
        return response
    except Exception as e:
        print(f"Request failed: {e}", file=sys.stderr)
        raise

def main():
    try:
        # Read input data
        data = json.load(sys.stdin)
        
        # Get backend URL from environment
        backend_url = os.environ.get('BACKEND_URL', 'http://localhost:8080')
        
        # Prepare webhook payload
        webhook_payload = {
            "name": data.get("name", ""),
            "url": data.get("url", ""),
            "api_key": data.get("api_key", ""),
            "payload_type": data.get("payload_type", "JSON"),
            "trigger_type": data.get("trigger_type", "realtime"),
            "interval": data.get("interval", 300),
            "mailboxes": data.get("mailboxes", []),
            "filters": data.get("filters", {}),
            "active": data.get("active", True)
        }
        
        # Make request to create webhook
        response = make_request(
            'POST', 
            f"{backend_url}/api/v1/webhooks",
            json=webhook_payload,
            headers={'Content-Type': 'application/json'}
        )
        
        if response.status_code in [200, 201]:
            result = response.json()
        else:
            print(f"Backend request failed with status {response.status_code}: {response.text}", file=sys.stderr)
            sys.exit(1)
        
        # Output result
        json.dump(result, fp=sys.stdout, indent=2)
        sys.exit(0)  # Explicit success exit
        
    except Exception as e:
        print(f"Error creating webhook: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
