import json
import sys
import os
import subprocess
import agent

# Get module instance information
status = {
    "instance": os.environ.get('MODULE_ID', ''),
    "ui_name": "",  # UI display name for the instance
    "node": os.environ.get('NODE_ID', '1'),
    "node_ui_name": "",  # UI display name for the node
    "services": [],
    "images": [],
    "volumes": []
}

# Get systemd services status
try:
    # Check our specific mail-webhooks service
    service_name = "mail-webhooks.service"
    
    try:
        # Check if service exists and get its status
        result = subprocess.run(
            ['systemctl', '--user', 'is-active', service_name], 
            capture_output=True, text=True
        )
        active = result.returncode == 0 and result.stdout.strip() == 'active'
        
        # Check if service is enabled
        result = subprocess.run(
            ['systemctl', '--user', 'is-enabled', service_name], 
            capture_output=True, text=True
        )
        enabled = result.returncode == 0 and result.stdout.strip() == 'enabled'
        
        # Check if service is failed
        result = subprocess.run(
            ['systemctl', '--user', 'is-failed', service_name], 
            capture_output=True, text=True
        )
        failed = result.returncode == 0 and result.stdout.strip() == 'failed'
        
        status['services'].append({
            'name': 'mail-webhooks',
            'active': active,
            'enabled': enabled,
            'failed': failed
        })
        
    except Exception as e:
        # If we can't check the service, report it as inactive
        status['services'].append({
            'name': 'mail-webhooks',
            'active': False,
            'enabled': False,
            'failed': True
        })
        
except Exception as e:
    print(f"Warning: Could not get services status: {e}", file=sys.stderr)

# Get container images
try:
    images_result = subprocess.run(['podman', 'images', '--format', 'json'], 
                                  capture_output=True, text=True, check=True)
    images_data = json.loads(images_result.stdout)
    
    module_images = []
    for image in images_data:
        image_names = image.get('Names', [])
        if any('mail-webhooks' in name for name in image_names):
            module_images.append({
                'name': image_names[0] if image_names else '',
                'size': str(image.get('Size', 0)),
                'created': image.get('Created', '')
            })
    
    status['images'] = module_images
except Exception as e:
    print(f"Warning: Could not get images status: {e}", file=sys.stderr)

# Get volumes
try:
    volumes_result = subprocess.run(['podman', 'volume', 'ls', '--format', 'json'], 
                                   capture_output=True, text=True, check=True)
    volumes_data = json.loads(volumes_result.stdout)
    
    module_volumes = []
    for volume in volumes_data:
        volume_name = volume.get('Name', '')
        module_id = os.environ.get('MODULE_ID', '')
        if module_id and module_id in volume_name:
            module_volumes.append({
                'name': volume_name,
                'mount': volume.get('Mountpoint', ''),
                'created': volume.get('CreatedAt', '')
            })
    
    status['volumes'] = module_volumes
except Exception as e:
    print(f"Warning: Could not get volumes status: {e}", file=sys.stderr)

# Output single JSON object
json.dump(status, fp=sys.stdout)
sys.exit(0)
