import json
import sys
import os
import subprocess
import agent

# Get module instance information
status = {
    "instance": os.environ.get('MODULE_ID', ''),
    "node": int(os.environ.get('NODE_ID', 0)),
    "services": [],
    "images": [],
    "volumes": []
}

# Get systemd services status
try:
    services_result = subprocess.run(['systemctl', '--user', 'list-units', '--type=service', '--output=json'], 
                                    capture_output=True, text=True, check=True)
    services_data = json.loads(services_result.stdout)
    
    # Filter services related to this module
    module_services = []
    for service in services_data:
        service_name = service.get('unit', '')
        if 'mail-webhooks' in service_name:
            module_services.append({
                'name': service_name,
                'active': service.get('active') == 'active',
                'enabled': service.get('sub') == 'running',
                'failed': service.get('active') == 'failed'
            })
    
    status['services'] = module_services
except Exception as e:
    print(f"Warning: Could not get services status: {e}", file=sys.stderr)

# Get container images
try:
    images_result = subprocess.run(['podman', 'images', '--format', 'json'], 
                                  capture_output=True, text=True, check=True)
    images_data = json.loads(images_result.stdout)
    
    module_images = []
    for image in images_data:
        if 'mail-webhooks' in str(image.get('Names', [])):
            module_images.append({
                'name': image.get('Names', [''])[0] if image.get('Names') else '',
                'size': str(image.get('Size', 0)),
                'created': image.get('Created', '')
            })
    
    status['images'] = module_images
except Exception as e:
    print(f"Warning: Could not get images status: {e}", file=sys.stderr)

# Get volumes
try:
    volumes_result = subprocess.run(['podman', 'volume', 'ls', '--format', 'json'], 
                                   capture_output=True, text=True, check=True)
    volumes_data = json.loads(volumes_result.stdout)
    
    module_volumes = []
    for volume in volumes_data:
        volume_name = volume.get('Name', '')
        if os.environ.get('MODULE_ID', '') in volume_name:
            module_volumes.append({
                'name': volume_name,
                'mount': volume.get('Mountpoint', ''),
                'created': volume.get('CreatedAt', '')
            })
    
    status['volumes'] = module_volumes
except Exception as e:
    print(f"Warning: Could not get volumes status: {e}", file=sys.stderr)

json.dump(status, fp=sys.stdout)
sys.exit(0)
