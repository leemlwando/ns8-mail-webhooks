{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "edit-webhook output",
    "$id": "http://schema.nethserver.org/mail-webhooks/edit-webhook-output.json",
    "description": "Updated webhook details",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Unique webhook identifier"
        },
        "email": {
            "type": "string",
            "format": "email",
            "description": "Email address to monitor"
        },
        "url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook URL endpoint"
        },
        "enabled": {
            "type": "boolean",
            "description": "Whether webhook is active"
        },
        "post_action": {
            "type": "string",
            "enum": ["none", "mark_as_read", "delete"],
            "description": "Action to perform after webhook trigger"
        },
        "payload_type": {
            "type": "string",
            "enum": ["raw", "json"],
            "description": "Format of webhook payload"
        },
        "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Webhook creation timestamp"
        },
        "is_realtime": {
            "type": "boolean",
            "description": "Whether webhook monitors emails in real-time"
        },
        "schedule_type": {
            "type": "string",
            "enum": ["hours", "custom"],
            "description": "Type of schedule interval for non-realtime webhooks"
        },
        "schedule_hours": {
            "type": "integer",
            "minimum": 1,
            "maximum": 24,
            "description": "Interval in hours for scheduled webhooks"
        },
        "schedule_custom": {
            "type": "string",
            "description": "Custom interval specification"
        },
        "last_triggered": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Last webhook trigger timestamp"
        },
        "last_run": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Last webhook run timestamp"
        },
        "next_run": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Next scheduled webhook run timestamp"
        },
        "trigger_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of times webhook has been triggered"
        },
        "run_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of times webhook has been run"
        }
    },
    "required": ["id", "email", "url", "enabled", "post_action", "payload_type", "created_at", "is_realtime", "schedule_type", "schedule_hours", "schedule_custom", "trigger_count", "run_count"],
    "additionalProperties": false
}
