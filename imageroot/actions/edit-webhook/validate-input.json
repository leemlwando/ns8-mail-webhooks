{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "edit-webhook input",
    "$id": "http://schema.nethserver.org/mail-webhooks/edit-webhook-input.json",
    "description": "Edit an existing email webhook",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Webhook ID to edit"
        },
        "email": {
            "type": "string",
            "format": "email",
            "description": "Email address to monitor"
        },
        "url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook URL endpoint"
        },
        "enabled": {
            "type": "boolean",
            "description": "Whether webhook is active"
        },
        "is_realtime": {
            "type": "boolean",
            "description": "Whether webhook monitors emails in real-time"
        },
        "schedule_type": {
            "type": "string",
            "enum": ["hours", "custom"],
            "description": "Type of schedule interval for non-realtime webhooks"
        },
        "schedule_hours": {
            "type": "integer",
            "minimum": 1,
            "maximum": 24,
            "description": "Interval in hours for scheduled webhooks"
        },
        "schedule_custom": {
            "type": "string",
            "description": "Custom interval specification (seconds, math expression, or time format)"
        },
        "post_action": {
            "type": "string",
            "enum": ["none", "mark_as_read", "delete"],
            "description": "Action to perform after webhook trigger"
        },
        "payload_type": {
            "type": "string",
            "enum": ["raw", "json"],
            "description": "Format of webhook payload"
        }
    },
    "required": ["id", "email", "url", "enabled", "post_action", "payload_type"],
    "additionalProperties": false
}
