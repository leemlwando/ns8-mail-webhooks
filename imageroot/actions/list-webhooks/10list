import json
import sys
import os
import requests
import urllib3

# Disable SSL warnings for internal API calls
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

try:
    # Get the API endpoint
    api_port = os.environ.get('TCP_PORT', '8080')
    api_url = f"http://127.0.0.1:{api_port}/api/webhooks"
    
    # Make API request
    response = requests.get(api_url, timeout=10)
    
    if response.status_code == 200:
        webhooks = response.json()
        json.dump(webhooks, fp=sys.stdout)
    else:
        print(f"API request failed: {response.status_code} - {response.text}", file=sys.stderr)
        json.dump({"error": f"API request failed: {response.status_code}"}, fp=sys.stdout)
    
    sys.exit(0)
    
except Exception as e:
    print(f"Error listing webhooks: {e}", file=sys.stderr)
    json.dump({"error": str(e)}, fp=sys.stdout)
    sys.exit(1)
