import subprocess
import os
import sys

def check_service_file(service_name):
    """Check if systemd service file exists and is valid"""
    service_path = os.path.expanduser(f"~/.config/systemd/user/{service_name}")
    
    if not os.path.exists(service_path):
        print(f"Service file missing: {service_path}", file=sys.stderr)
        return False
    
    print(f"Found service file: {service_name}")
    
    # Check if service file can be parsed by systemd
    try:
        result = subprocess.run(
            ['systemctl', '--user', 'cat', service_name.replace('.service', '')],
            check=True, 
            capture_output=True, 
            text=True
        )
        print(f"Service file {service_name} is valid")
        return True
    except subprocess.CalledProcessError as e:
        print(f"Invalid service file {service_name}: {e.stderr}", file=sys.stderr)
        return False

def check_environment_file():
    """Check if environment file exists and has required variables"""
    env_path = os.path.expanduser("~/state/environment")
    
    if not os.path.exists(env_path):
        print(f"Environment file missing: {env_path}", file=sys.stderr)
        return False
    
    # Check required variables
    required_vars = ['MAIL_WEBHOOK_IMAGE', 'TCP_PORT', 'MODULE_ID', 'DATABASE_PATH']
    
    try:
        with open(env_path, 'r') as f:
            env_content = f.read()
    except Exception as e:
        print(f"Cannot read environment file: {e}", file=sys.stderr)
        return False
    
    missing_vars = []
    for var in required_vars:
        if f"{var}=" not in env_content:
            missing_vars.append(var)
    
    if missing_vars:
        print(f"Missing environment variables: {', '.join(missing_vars)}", file=sys.stderr)
        return False
    
    print("Environment file is valid")
    return True

def check_database_file():
    """Check if database file exists and is accessible"""
    db_path = os.path.expanduser("~/data/webhooks.db")
    
    if not os.path.exists(db_path):
        print(f"Database file missing: {db_path}", file=sys.stderr)
        return False
    
    # Check if database is readable
    try:
        import sqlite3
        with sqlite3.connect(db_path) as conn:
            cursor = conn.execute("SELECT name FROM sqlite_master WHERE type='table'")
            tables = [row[0] for row in cursor.fetchall()]
            
        expected_tables = ['webhook_configs', 'jobs', 'processing_logs', 'app_config']
        missing_tables = [table for table in expected_tables if table not in tables]
        
        if missing_tables:
            print(f"Database missing tables: {', '.join(missing_tables)}", file=sys.stderr)
            return False
            
        print("Database file is valid")
        return True
        
    except Exception as e:
        print(f"Database validation failed: {e}", file=sys.stderr)
        return False

def main():
    """Run all validation checks"""
    checks = [
        ("Environment file", check_environment_file),
        ("Database file", check_database_file),
        ("Main service", lambda: check_service_file('mail-webhooks.service')),
        ("Worker service", lambda: check_service_file('mail-webhook-worker.service')),
    ]
    
    failed_checks = []
    
    for check_name, check_func in checks:
        print(f"Validating {check_name}...")
        try:
            if not check_func():
                failed_checks.append(check_name)
        except Exception as e:
            print(f"Validation error for {check_name}: {e}", file=sys.stderr)
            failed_checks.append(check_name)
    
    if failed_checks:
        print(f"Validation failed for: {', '.join(failed_checks)}", file=sys.stderr)
        sys.exit(1)
    
    print("All service validations passed")

if __name__ == "__main__":
    main()
