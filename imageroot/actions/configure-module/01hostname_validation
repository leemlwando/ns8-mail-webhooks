import os
import sys
import json
import agent

agent.set_weight(os.path.basename(__file__), 0) # Validation step, no task progress at all

try:
    # retrieve json data
    data = json.load(sys.stdin)

    # Setup default values
    hostname = data.get("hostname", "")
    
    # Skip validation if no hostname is provided (optional field)
    if not hostname:
        sys.exit(0)
    
    # do not test if it is the same host
    old_hostname = os.environ.get('TRAEFIK_HOST', '')

    if hostname != old_hostname and agent.http_route_in_use(domain=hostname):
        agent.set_status('validation-failed')
        json.dump([{
            'field': 'hostname',
            'parameter': 'hostname',
            'value': hostname,
            'error': 'domain_already_used_in_traefik'
        }], fp=sys.stdout)
        sys.exit(2)

except Exception as e:
    print(f"Error in hostname validation: {e}", file=sys.stderr)
    sys.exit(1)
