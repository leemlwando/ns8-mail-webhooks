import json
import sys
import agent

agent.set_weight(0, 0) # Validation step, no task progress at all

# Parse the configuration request
data = json.load(sys.stdin)

# Validate required fields
if not data.get("mongodb_url"):
    agent.set_status('validation-failed')
    json.dump([{
        'field': 'mongodb_url',
        'parameter': 'mongodb_url', 
        'value': data.get("mongodb_url", ""),
        'error': 'mongodb_url_is_required'
    }], fp=sys.stdout)
    sys.exit(2)

# Validate MongoDB URL format (basic check)
mongodb_url = data["mongodb_url"]
if not (mongodb_url.startswith("mongodb://") or mongodb_url.startswith("mongodb+srv://")):
    agent.set_status('validation-failed')
    json.dump([{
        'field': 'mongodb_url',
        'parameter': 'mongodb_url',
        'value': mongodb_url,
        'error': 'mongodb_url_invalid_format'
    }], fp=sys.stdout)
    sys.exit(2)

# Validate FQDN if provided
if "hostname" in data and data["hostname"]:
    hostname = data["hostname"]
    
    # Check if domain is already in use by another service
    if hostname != agent.get_env('TRAEFIK_HOST', '') and agent.http_route_in_use(domain=hostname):
        agent.set_status('validation-failed')
        json.dump([{
            'field': 'hostname',
            'parameter': 'hostname',
            'value': hostname,            'error': 'domain_already_used_in_traefik'
        }], fp=sys.stdout)
        sys.exit(2)

# Validation successful
print("Validation completed successfully", file=sys.stderr)
sys.exit(0)
