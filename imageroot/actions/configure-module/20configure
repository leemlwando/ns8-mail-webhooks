import json
import sys
import agent
import agent.tasks
import os

try:
    request = json.load(sys.stdin)
except json.JSONDecodeError as e:
    print(f"Error: Invalid JSON input: {e}", file=sys.stderr)
    sys.exit(1)

print(f"Received configuration request: {request}", file=sys.stderr)

# Validate required configuration
if "mongodb_url" not in request:
    print("Error: mongodb_url is required for configuration", file=sys.stderr)
    sys.exit(1)

print(f"Setting environment variables...", file=sys.stderr)

# Set MongoDB URL from request
agent.set_env("MONGODB_URL", request["mongodb_url"])

# Set mail server UUID if provided
if "mail_server_uuid" in request:
    agent.set_env("MAIL_SERVER_UUID", request["mail_server_uuid"])

# Set collection names with defaults
agent.set_env("WEBHOOKS_COLLECTION", request.get("webhooks_collection", "webhooks"))
agent.set_env("EVENTS_COLLECTION", request.get("events_collection", "events"))
agent.set_env("SETTINGS_COLLECTION", request.get("settings_collection", "settings"))
agent.set_env("TRIGGERS_COLLECTION", request.get("triggers_collection", "triggers"))
agent.set_env("LOGS_COLLECTION", request.get("logs_collection", "logs"))

print(f"Environment variables set successfully", file=sys.stderr)

# Configure Traefik to route "/mail-webhooks" path requests to the service
print(f"Configuring Traefik route...", file=sys.stderr)
response = agent.tasks.run(
    agent_id=agent.resolve_agent_id('traefik@node'),
    action='set-route',
    data={
        'instance': os.environ['MODULE_ID'],
        'url': 'http://127.0.0.1:' + os.environ["TCP_PORT"],
        'http2https': request.get('http2https', False),
        'lets_encrypt': request.get('lets_encrypt', False),
        'path': '/mail-webhooks',
    },
)

# Check if traefik configuration has been successful
agent.assert_exp(response['exit_code'] == 0)
print(f"Traefik route configured successfully", file=sys.stderr)

print(f"Mail Webhooks module configured successfully")
print(f"MongoDB URL: {request['mongodb_url']}")
print(f"Collection names: webhooks={request.get('webhooks_collection', 'webhooks')}, events={request.get('events_collection', 'events')}, settings={request.get('settings_collection', 'settings')}, triggers={request.get('triggers_collection', 'triggers')}, logs={request.get('logs_collection', 'logs')}")
print(f"Access URL: https://<server>/mail-webhooks")