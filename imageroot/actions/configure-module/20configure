import json
import sys
import agent
import agent.tasks
import os
import uuid

def create_directories():
    """Create required directory structure"""
    directories = ['state', 'state/data']
    
    for directory in directories:
        os.makedirs(directory, exist_ok=True)
        print(f"Created directory: {directory}")

def create_environment_file():
    """Create environment configuration file"""
    # Generate unique module identifier
    module_uuid = str(uuid.uuid4())
    
    # Get configuration values
    tcp_port = os.environ.get("TCP_PORT", "8080")
    image_name = os.environ.get("MAIL_WEBHOOK_IMAGE", "ghcr.io/nethserver/mail-webhook:latest")
    module_id = os.environ.get("MODULE_ID", "mail-webhook")
    
    # Create environment configuration
    env_config = {
        'MAIL_WEBHOOK_IMAGE': image_name,
        'TCP_PORT': tcp_port,
        'MODULE_ID': module_id,
        'MODULE_UUID': module_uuid,
        'DATABASE_PATH': '/var/lib/nethserver/mail-webhook/webhooks.db',
        'LOG_LEVEL': 'INFO',
        'CHECK_INTERVAL': '60',
        'IMAP_HOST': os.environ.get('MAIL_SERVER', 'localhost'),
        'IMAP_PORT': '993',
        'IMAP_SSL': 'true',
        'MAIL_ADMIN_USER': os.environ.get('MAIL_ADMIN_USER', 'admin'),
        'MAIL_ADMIN_PASS': os.environ.get('MAIL_ADMIN_PASS', ''),
        'WEBHOOK_TIMEOUT': '30',
        'MAX_RETRIES': '3',
        'MAX_EMAILS_PER_BATCH': '50',
        'BATCH_PROCESSING_DELAY': '1000',
    }
    
    # Write environment file
    env_path = 'state/environment'
    with open(env_path, 'w') as f:
        for key, value in env_config.items():
            f.write(f'{key}={value}\n')
    
    # Set secure permissions
    os.chmod(env_path, 0o600)
    print(f"Created environment file: {env_path}")

def configure_traefik_routing():
    """Configure Traefik HTTP routing"""
    tcp_port = os.environ.get("TCP_PORT", "8080")
    module_id = os.environ.get("MODULE_ID", "mail-webhook")
    
    # Configure Traefik to route requests to the mail-webhooks service
    response = agent.tasks.run(
        agent_id=agent.resolve_agent_id('traefik@node'),
        action='set-route',
        data={
            'instance': module_id,
            'url': f'http://127.0.0.1:{tcp_port}',
            'http2https': True,
            'lets_encrypt': True,
            'path': '/mail-webhooks',
        },
    )
    
    # Validate Traefik configuration
    agent.assert_exp(response['exit_code'] == 0, "Failed to configure Traefik routing")
    print(f"Configured Traefik route for /mail-webhooks -> 127.0.0.1:{tcp_port}")

def main():
    """Main configuration function"""
    try:
        # Read input configuration if provided
        request = json.load(sys.stdin)
    except json.JSONDecodeError:
        request = {}
    
    print("Starting module configuration...")
    
    # Execute configuration steps
    create_directories()
    create_environment_file()
    configure_traefik_routing()
    
    print("Module configuration completed successfully")

if __name__ == "__main__":
    main()
