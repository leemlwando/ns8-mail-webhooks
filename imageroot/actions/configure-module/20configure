import json
import sys
import agent
import os

def main():
    """Main configuration function"""
    try:
        # Read input configuration
        request = json.load(sys.stdin)
    except json.JSONDecodeError:
        request = {}
    
    print("Starting mail webhook module configuration...")
    
    # Set environment variables based on configuration
    if 'webhook_server_enabled' in request:
        agent.set_env("WEBHOOK_SERVER_ENABLED", str(request['webhook_server_enabled']).lower())
    else:
        agent.set_env("WEBHOOK_SERVER_ENABLED", "true")

    if 'webhook_server_url' in request:
        agent.set_env("WEBHOOK_SERVER_URL", request['webhook_server_url'])
    else:
        # Default webhook server URL
        agent.set_env("WEBHOOK_SERVER_URL", "http://127.0.0.1:8080")

    if 'webhook_server_image' in request:
        agent.set_env("WEBHOOK_SERVER_IMAGE", request['webhook_server_image'])
    else:
        # Default webhook server image
        agent.set_env("WEBHOOK_SERVER_IMAGE", "ghcr.io/leemlwando/ns8-mail-webhooks-server:latest")

    # IMAP configuration for webhook server
    if 'imap_server' in request:
        agent.set_env("IMAP_SERVER", request['imap_server'])
    else:
        agent.set_env("IMAP_SERVER", "localhost")

    if 'imap_port' in request:
        agent.set_env("IMAP_PORT", str(request['imap_port']))
    else:
        agent.set_env("IMAP_PORT", "993")

    if 'imap_username' in request:
        agent.set_env("IMAP_USERNAME", request['imap_username'])

    if 'imap_password' in request:
        agent.set_env("IMAP_PASSWORD", request['imap_password'])

    # Database configuration for webhook server
    if 'mongodb_url' in request:
        agent.set_env("MONGODB_URL", request['mongodb_url'])
    else:
        # Default MongoDB URL
        agent.set_env("MONGODB_URL", "mongodb://127.0.0.1:27017/webhooks")

    if 'redis_url' in request:
        agent.set_env("REDIS_URL", request['redis_url'])
    else:
        # Default Redis URL
        agent.set_env("REDIS_URL", "redis://127.0.0.1:6379")

    # Debug mode
    if 'debug' in request:
        agent.set_env("DEBUG", str(request['debug']).lower())
    else:
        agent.set_env("DEBUG", "false")

    print("Mail webhook module configuration completed successfully")

if __name__ == "__main__":
    main()
