import os
import sys
import agent

try:
    backend_image = os.environ.get('BACKEND_IMAGE', 'ghcr.io/nethserver/mail-webhooks-backend:latest')
    if backend_image:
        try:
            agent.run_helper("podman", "pull", backend_image).check_returncode()
        except Exception as e:
            print(f"Warning: Could not pull backend image: {e}", file=sys.stderr)
    sys.exit(0)
except Exception as e:
    print(f"Error ensuring backend image: {e}", file=sys.stderr)
    sys.exit(0)
