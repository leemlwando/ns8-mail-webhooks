{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "configure-module input",
  "description": "Configure the mail webhook module",
  "type": "object",
  "properties": {
    "webhook_server_enabled": {
      "type": "boolean",
      "description": "Enable the webhook server",
      "default": true
    },
    "webhook_server_url": {
      "type": "string",
      "description": "Webhook server URL",
      "format": "uri",
      "default": "http://127.0.0.1:8080"
    },
    "webhook_server_image": {
      "type": "string",
      "description": "Webhook server container image",
      "default": "ghcr.io/leemlwando/ns8-mail-webhooks-server:latest"
    },
    "imap_server": {
      "type": "string",
      "description": "IMAP server hostname",
      "default": "localhost"
    },
    "imap_port": {
      "type": "integer",
      "description": "IMAP server port",
      "minimum": 1,
      "maximum": 65535,
      "default": 993
    },
    "imap_username": {
      "type": "string",
      "description": "IMAP username for mail monitoring"
    },
    "imap_password": {
      "type": "string",
      "description": "IMAP password for mail monitoring"
    },
    "mongodb_url": {
      "type": "string",
      "description": "MongoDB connection URL",
      "default": "mongodb://127.0.0.1:27017/webhooks"
    },
    "redis_url": {
      "type": "string",
      "description": "Redis connection URL",
      "default": "redis://127.0.0.1:6379"
    },
    "debug": {
      "type": "boolean",
      "description": "Enable debug mode",
      "default": false
    }
  },
  "additionalProperties": false
}
