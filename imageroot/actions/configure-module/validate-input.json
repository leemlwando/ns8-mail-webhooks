{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "configure-module input",
    "$id": "http://schema.nethserver.org/mail-webhooks/configure-module-input.json",
    "description": "Configure mail-webhooks module",
    "type": "object",
    "properties": {
        "imap_host": {
            "type": "string",
            "description": "IMAP server hostname",
            "default": "127.0.0.1"
        },
        "imap_port": {
            "type": "integer",
            "description": "IMAP server port",
            "default": 993,
            "minimum": 1,
            "maximum": 65535
        },
        "polling_interval": {
            "type": "integer",
            "description": "Polling interval in seconds",
            "default": 60,
            "minimum": 10,
            "maximum": 3600
        }
    },
    "additionalProperties": true
}