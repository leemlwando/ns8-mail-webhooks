set -e
exec 1>&2

# Ensure the backend image is available
if [[ -n "${MAIL_WEBHOOKS_BACKEND_IMAGE}" ]]; then
    echo "Backend image environment variable set: ${MAIL_WEBHOOKS_BACKEND_IMAGE}"
    
    # Check if image exists locally
    if podman image exists "${MAIL_WEBHOOKS_BACKEND_IMAGE}"; then
        echo "Backend image already exists locally"
    else
        echo "Backend image not found locally, attempting to build..."
        
        # Build the backend image using the Containerfile in the api directory
        cd /imageroot/api
        if podman build -t "${MAIL_WEBHOOKS_BACKEND_IMAGE}" .; then
            echo "Successfully built backend image: ${MAIL_WEBHOOKS_BACKEND_IMAGE}"
        else
            echo "Error: Failed to build backend image"
            exit 1
        fi
        
        # Verify the image was created
        if podman image exists "${MAIL_WEBHOOKS_BACKEND_IMAGE}"; then
            echo "Backend image verified: ${MAIL_WEBHOOKS_BACKEND_IMAGE}"
        else
            echo "Error: Backend image was not created properly"
            exit 1
        fi
    fi
else
    echo "Error: MAIL_WEBHOOKS_BACKEND_IMAGE environment variable not set"
    exit 1
fi
