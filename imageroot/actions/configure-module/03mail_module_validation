import json
import sys
import os
import agent

agent.set_weight(os.path.basename(__file__), 0) # Validation step, no task progress at all

try:
    # This module requires NS8 mail module to be available
    # No external mail servers or fallback mechanisms are supported
    
    # Check if any NS8 mail modules are available
    mail_providers = []
    
    # Use Redis to find mail module services
    with agent.redis_connect() as rdb:
        # Look for mail module service endpoints
        mail_service_keys = rdb.keys('module/mail*/srv/tcp/*')
        
        for key in mail_service_keys:
            try:
                service_info = rdb.hgetall(key)
                if service_info and service_info.get('host'):
                    # Extract module ID from key (e.g., mail1, mail2)
                    key_parts = key.split('/')
                    if len(key_parts) >= 2:
                        module_id = key_parts[1]
                        mail_providers.append({
                            'module_id': module_id,
                            'host': service_info.get('host'),
                            'port': service_info.get('port')
                        })
            except Exception as e:
                # Skip this service if there's an error
                continue
    
    if not mail_providers:
        # No NS8 mail modules found - this is a fatal error
        agent.set_status('validation-failed')
        json.dump([{
            'field': 'mail_integration',
            'parameter': 'mail_integration',
            'value': '',
            'error': 'ns8_mail_module_required'
        }], fp=sys.stdout)
        sys.exit(3)
    
    # Log successful mail module discovery
    agent.log_info(f"Found {len(mail_providers)} NS8 mail module(s): {[p.get('module_id', 'unknown') for p in mail_providers]}")
    
except Exception as e:
    # Any exception in mail module discovery is treated as validation failure
    agent.set_status('validation-failed')
    json.dump([{
        'field': 'mail_integration',
        'parameter': 'mail_integration', 
        'value': '',
        'error': f'mail_module_discovery_failed: {str(e)}'
    }], fp=sys.stdout)
    sys.exit(3)
