{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "configure-module input",
    "$id": "http://schema.nethserver.org/mail-webhooks/configure-module-input.json",
    "description": "Configure mail-webhooks module with optional initial configuration",
    "type": "object",
    "properties": {
        "webhook_configs": {
            "type": "array",
            "description": "Initial webhook configurations to create",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Name for the webhook configuration"
                    },
                    "mailbox": {
                        "type": "string",
                        "format": "email",
                        "description": "Source mailbox email address"
                    },
                    "webhook_url": {
                        "type": "string",
                        "format": "uri",
                        "description": "Target webhook URL"
                    },
                    "api_key": {
                        "type": "string",
                        "description": "Optional API key for webhook authentication"
                    },
                    "payload_format": {
                        "type": "string",
                        "enum": ["json", "raw"],
                        "default": "json",
                        "description": "Format for webhook payload"
                    },
                    "post_processing": {
                        "type": "string",
                        "enum": ["mark_read", "delete", "none"],
                        "default": "mark_read",
                        "description": "Action to take on processed emails"
                    },
                    "schedule_interval": {
                        "type": "integer",
                        "minimum": 60,
                        "maximum": 86400,
                        "default": 300,
                        "description": "Check interval in seconds"
                    }
                },
                "required": ["name", "mailbox", "webhook_url"],
                "additionalProperties": false
            }
        },
        "imap_config": {
            "type": "object",
            "description": "IMAP server configuration",
            "properties": {
                "host": {
                    "type": "string",
                    "description": "IMAP server hostname"
                },
                "port": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535,
                    "default": 993,
                    "description": "IMAP server port"
                },
                "use_ssl": {
                    "type": "boolean",
                    "default": true,
                    "description": "Use SSL/TLS encryption"
                },
                "admin_user": {
                    "type": "string",
                    "description": "Admin username for IMAP access"
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false,
    "examples": [
        {},
        {
            "webhook_configs": [
                {
                    "name": "Support Tickets",
                    "mailbox": "support@example.com",
                    "webhook_url": "https://api.example.com/webhooks/support",
                    "payload_format": "json",
                    "post_processing": "mark_read"
                }
            ],
            "imap_config": {
                "host": "mail.example.com",
                "port": 993,
                "use_ssl": true
            }
        }
    ]
}