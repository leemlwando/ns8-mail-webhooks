import os
import sqlite3
import sys

def create_database_directory():
    """Create the database directory with proper permissions"""
    db_dir = os.path.expanduser("~/data")
    os.makedirs(db_dir, exist_ok=True)
    os.chmod(db_dir, 0o755)
    print(f"Created database directory: {db_dir}")

def initialize_database():
    """Initialize SQLite database with required schema"""
    db_path = os.path.expanduser("~/data/webhooks.db")
    
    try:
        with sqlite3.connect(db_path) as conn:
            # Enable WAL mode for better concurrent access
            conn.execute('PRAGMA journal_mode=WAL;')
            conn.execute('PRAGMA synchronous=NORMAL;')
            conn.execute('PRAGMA foreign_keys=ON;')
            
            # Create webhook configurations table
            conn.execute("""
                CREATE TABLE IF NOT EXISTS webhook_configs (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    name TEXT UNIQUE NOT NULL,
                    mailbox TEXT NOT NULL,
                    webhook_url TEXT NOT NULL,
                    api_key TEXT,
                    payload_format TEXT DEFAULT 'json',
                    post_processing TEXT DEFAULT 'mark_read',
                    schedule_interval INTEGER DEFAULT 300,
                    is_active BOOLEAN DEFAULT 1,
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                )
            """)
            
            # Create jobs table
            conn.execute("""
                CREATE TABLE IF NOT EXISTS jobs (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    name TEXT NOT NULL,
                    job_type TEXT NOT NULL,
                    mailbox TEXT NOT NULL,
                    webhook_url TEXT NOT NULL,
                    api_key TEXT,
                    payload_format TEXT DEFAULT 'json',
                    post_processing TEXT DEFAULT 'mark_read',
                    status TEXT DEFAULT 'pending',
                    emails_processed INTEGER DEFAULT 0,
                    error_message TEXT,
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    started_at TIMESTAMP NULL,
                    completed_at TIMESTAMP NULL
                )
            """)
            
            # Create processing logs table
            conn.execute("""
                CREATE TABLE IF NOT EXISTS processing_logs (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    job_id INTEGER,
                    config_id INTEGER,
                    message_id TEXT,
                    subject TEXT,
                    sender TEXT,
                    webhook_url TEXT,
                    status TEXT,
                    error_message TEXT,
                    response_code INTEGER,
                    processed_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    FOREIGN KEY (job_id) REFERENCES jobs (id),
                    FOREIGN KEY (config_id) REFERENCES webhook_configs (id)
                )
            """)
            
            # Create configuration table
            conn.execute("""
                CREATE TABLE IF NOT EXISTS app_config (
                    key TEXT PRIMARY KEY,
                    value TEXT NOT NULL,
                    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                )
            """)
            
            # Create indexes for better performance
            conn.execute("""
                CREATE INDEX IF NOT EXISTS idx_logs_job_date 
                ON processing_logs(job_id, processed_at DESC)
            """)
            
            conn.execute("""
                CREATE INDEX IF NOT EXISTS idx_logs_config_date 
                ON processing_logs(config_id, processed_at DESC)
            """)
            
            conn.execute("""
                CREATE INDEX IF NOT EXISTS idx_logs_status 
                ON processing_logs(status, processed_at DESC)
            """)
            
            conn.execute("""
                CREATE INDEX IF NOT EXISTS idx_jobs_status 
                ON jobs(status, created_at DESC)
            """)
            
            conn.execute("""
                CREATE INDEX IF NOT EXISTS idx_configs_active 
                ON webhook_configs(is_active, updated_at DESC)
            """)
            
            # Insert default configuration
            default_configs = [
                ('imap_host', 'localhost'),
                ('imap_port', '993'),
                ('imap_ssl', 'true'),
                ('webhook_timeout', '30'),
                ('max_retries', '3'),
                ('log_level', 'INFO'),
                ('max_emails_per_batch', '50'),
                ('batch_processing_delay', '1000'),
            ]
            
            for key, value in default_configs:
                conn.execute("""
                    INSERT OR IGNORE INTO app_config (key, value) 
                    VALUES (?, ?)
                """, (key, value))
            
            conn.commit()
        
        # Set secure permissions on database file
        os.chmod(db_path, 0o660)
        print(f"Database initialized successfully: {db_path}")
        
    except Exception as e:
        print(f"Database initialization failed: {e}", file=sys.stderr)
        sys.exit(1)

def main():
    create_database_directory()
    initialize_database()
    print("Database setup completed successfully")

if __name__ == "__main__":
    main()
