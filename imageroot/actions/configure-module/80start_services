import subprocess
import time
import sys
import os

def reload_systemd():
    """Reload systemd configuration"""
    try:
        subprocess.run(['systemctl', '--user', 'daemon-reload'], check=True)
        print("Reloaded systemd configuration")
    except subprocess.CalledProcessError as e:
        print(f"Failed to reload systemd: {e}", file=sys.stderr)
        return False
    return True

def enable_and_start_service(service_name, wait_time=3):
    """Enable and start a systemd service with validation"""
    try:
        # Enable service
        subprocess.run(['systemctl', '--user', 'enable', service_name], check=True)
        print(f"Enabled {service_name}")
        
        # Start service
        subprocess.run(['systemctl', '--user', 'start', service_name], check=True)
        print(f"Started {service_name}")
        
        # Wait for startup
        time.sleep(wait_time)
        
        # Check if service is active
        result = subprocess.run(
            ['systemctl', '--user', 'is-active', service_name], 
            capture_output=True, 
            text=True
        )
        
        if result.returncode == 0 and result.stdout.strip() == 'active':
            print(f"Service {service_name} is running successfully")
            return True
        else:
            # Get detailed status for debugging
            status_result = subprocess.run(
                ['systemctl', '--user', 'status', service_name], 
                capture_output=True, 
                text=True
            )
            print(f"Service {service_name} failed to start properly", file=sys.stderr)
            print(f"Status output: {status_result.stdout}", file=sys.stderr)
            return False
            
    except subprocess.CalledProcessError as e:
        print(f"Failed to start {service_name}: {e}", file=sys.stderr)
        if e.stderr:
            print(f"Error details: {e.stderr}", file=sys.stderr)
        return False

def create_smarthost_env():
    """Create smarthost.env file for compatibility"""
    smarthost_path = os.path.expanduser("~/smarthost.env")
    if not os.path.exists(smarthost_path):
        with open(smarthost_path, 'w') as f:
            f.write("# Smarthost configuration for mail webhook module\n")
            f.write("# This file is created for compatibility\n")
        print(f"Created {smarthost_path}")

def main():
    """Main service startup function"""
    print("Starting mail webhook services...")
    
    # Create required files
    create_smarthost_env()
    
    # Reload systemd configuration
    if not reload_systemd():
        sys.exit(1)
    
    # Define services in startup order
    services = [
        ('mail-webhooks.service', 5),        # Main app with longer wait time
        ('mail-webhook-worker.service', 3),  # Worker with shorter wait time
    ]
    
    started_services = []
    
    for service_name, wait_time in services:
        print(f"Starting {service_name}...")
        
        if enable_and_start_service(service_name, wait_time):
            started_services.append(service_name)
            print(f"✓ {service_name} started successfully")
        else:
            print(f"✗ Failed to start {service_name}", file=sys.stderr)
            
            # Stop any already started services on failure
            for started_service in started_services:
                try:
                    subprocess.run(['systemctl', '--user', 'stop', started_service], check=True)
                    print(f"Stopped {started_service} due to startup failure")
                except:
                    pass
            
            sys.exit(1)
        
        # Brief pause between service starts
        time.sleep(1)
    
    print("All services started successfully")
    
    # Final health check
    print("Performing final health check...")
    time.sleep(2)
    
    all_healthy = True
    for service_name, _ in services:
        result = subprocess.run(
            ['systemctl', '--user', 'is-active', service_name], 
            capture_output=True, 
            text=True
        )
        
        if result.returncode == 0 and result.stdout.strip() == 'active':
            print(f"✓ {service_name} is healthy")
        else:
            print(f"✗ {service_name} is not healthy", file=sys.stderr)
            all_healthy = False
    
    if not all_healthy:
        print("Some services are not healthy after startup", file=sys.stderr)
        sys.exit(1)
    
    print("Service startup completed successfully")

if __name__ == "__main__":
    main()
