# If the control reaches this step, the service can be enabled and started

echo "Starting mail-webhooks service configuration..." >&2

# Create required files
touch smarthost.env

echo "Environment variables in current context:" >&2
env | grep -E "(MONGODB|MAIL_|WEBHOOKS|EVENTS|SETTINGS|TRIGGERS|LOGS)" >&2

# Backend image should have been built by 30ensure_backend_image
echo "Backend image should be ready (built by 30ensure_backend_image)..." >&2

echo "Enabling and starting mail-webhooks.service..." >&2
systemctl --user enable --now mail-webhooks.service

echo "Checking service status..." >&2
systemctl --user status mail-webhooks.service --no-pager >&2

# Mail monitor service disabled for Phase 1 (API-only implementation)
if false; then  # [[ -n "${MONGODB_URL}" ]]; then
    echo "Starting mail monitor service..." >&2
    systemctl --user enable --now mail-monitor.service || true
    echo "Mail monitor service started" >&2
else
    echo "Mail monitor service disabled - Phase 1 implementation (API only)" >&2
fi

echo "Service startup completed" >&2
