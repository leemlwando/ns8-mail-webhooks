import sys
import subprocess
import os
import agent

print("Starting mail-webhooks service configuration...", file=sys.stderr)

# Create required files
subprocess.run(["touch", "smarthost.env"], check=True)

# Print environment variables for debugging
print("Environment variables in current context:", file=sys.stderr)
for key, value in os.environ.items():
    if any(prefix in key for prefix in ["MONGODB", "MAIL_", "WEBHOOKS", "EVENTS", "SETTINGS", "TRIGGERS", "LOGS"]):
        print(f"{key}={value}", file=sys.stderr)

print("Backend image should be ready (built by 30ensure_backend_image)...", file=sys.stderr)

# Enable and start the main service
print("Enabling and starting mail-webhooks.service...", file=sys.stderr)
try:
    subprocess.run([
        "systemctl", "--user", "enable", "--now", "mail-webhooks.service"
    ], check=True)
except subprocess.CalledProcessError as e:
    print(f"Error starting mail-webhooks.service: {e}", file=sys.stderr)
    sys.exit(1)

# Check service status
print("Checking service status...", file=sys.stderr)
try:
    subprocess.run([
        "systemctl", "--user", "status", "mail-webhooks.service", "--no-pager"
    ], check=False, stderr=subprocess.STDOUT)
except subprocess.CalledProcessError:
    # Status command might return non-zero even for running services
    pass

# Mail monitor service disabled for Phase 1 (API-only implementation)
mongodb_url = os.environ.get("MONGODB_URL", "")
if False:  # mongodb_url:  # Disabled for Phase 1
    print("Starting mail monitor service...", file=sys.stderr)
    try:
        subprocess.run([
            "systemctl", "--user", "enable", "--now", "mail-monitor.service"
        ], check=False)
        print("Mail monitor service started", file=sys.stderr)
    except subprocess.CalledProcessError:
        print("Warning: Failed to start mail monitor service", file=sys.stderr)
else:
    print("Mail monitor service disabled - Phase 1 implementation (API only)", file=sys.stderr)

print("Service startup completed", file=sys.stderr)
