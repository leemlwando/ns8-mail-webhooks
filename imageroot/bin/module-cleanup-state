#
# Standard module state cleanup utility
#

import os
import sys
import subprocess
import agent

# Stop services first
try:
    subprocess.run(['systemctl', '--user', 'stop', 'mail-webhooks.service'], 
                  check=False, capture_output=True)
except:
    pass

# Clean up data directories if requested
if '--no-preserve' in sys.argv or '--force' in sys.argv:
    import shutil
    
    for directory in ['data', 'logs']:
        try:
            if os.path.exists(directory):
                shutil.rmtree(directory)
                print(f"Removed {directory} directory", file=sys.stderr)
        except Exception as e:
            print(f"Warning: Could not remove {directory}: {e}", file=sys.stderr)

print("Module state cleanup completed", file=sys.stderr)
