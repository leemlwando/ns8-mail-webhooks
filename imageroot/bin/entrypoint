"""
Entrypoint for NethServer 8 Mail Webhooks module
"""

import os
import sys
import uvicorn

# Add the pypkg directory to Python path
sys.path.insert(0, '/imageroot/pypkg')

if __name__ == "__main__":
    # Start the FastAPI application
    uvicorn.run(
        "mailwebhook.main:app",
        host="0.0.0.0",
        port=8000,
        reload=False,
        log_level="info"
    )
