#!/usr/bin/env python3
"""
Mail Monitor Service Binary
Standalone service for monitoring mail servers and processing webhooks
"""

import os
import sys
import signal
import time
import logging
import argparse
from pathlib import Path

# Add the API directory to the Python path
api_dir = Path(__file__).parent.parent / 'api'
sys.path.insert(0, str(api_dir))

from mail_monitor import MailMonitorService

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    handlers=[
        logging.StreamHandler(),
        logging.FileHandler('/var/log/mail-webhooks-monitor.log') if os.path.exists('/var/log') else logging.NullHandler()
    ]
)

logger = logging.getLogger(__name__)

# Global service instance
service = None

def signal_handler(signum, frame):
    """Handle shutdown signals"""
    global service
    logger.info(f"Received signal {signum}, shutting down...")
    if service:
        service.stop_service()
    sys.exit(0)

def main():
    """Main entry point"""
    parser = argparse.ArgumentParser(description='Mail Webhooks Monitor Service')
    parser.add_argument(
        '--mongodb-url',
        default=os.getenv('MONGODB_URL'),
        help='MongoDB connection URL'
    )
    parser.add_argument(
        '--config-file',
        help='Path to configuration file'
    )
    parser.add_argument(
        '--daemon',
        action='store_true',
        help='Run as daemon'
    )
    parser.add_argument(
        '--pid-file',
        default='/var/run/mail-webhooks-monitor.pid',
        help='PID file path'
    )
    
    args = parser.parse_args()
    
    # Register signal handlers
    signal.signal(signal.SIGTERM, signal_handler)
    signal.signal(signal.SIGINT, signal_handler)
    
    # Validate MongoDB URL
    if not args.mongodb_url:
        logger.error("MongoDB URL is required. Set MONGODB_URL environment variable or use --mongodb-url")
        sys.exit(1)
    
    # Create PID file if running as daemon
    if args.daemon and args.pid_file:
        try:
            with open(args.pid_file, 'w') as f:
                f.write(str(os.getpid()))
            logger.info(f"PID file created: {args.pid_file}")
        except Exception as e:
            logger.error(f"Failed to create PID file: {e}")
    
    # Initialize and start the service
    global service
    service = MailMonitorService()
    
    try:
        logger.info("Starting Mail Webhooks Monitor Service...")
        service.start_service(args.mongodb_url)
        
        # Keep the service running
        while service.running:
            time.sleep(1)
            
    except KeyboardInterrupt:
        logger.info("Received keyboard interrupt")
    except Exception as e:
        logger.error(f"Service error: {e}")
        sys.exit(1)
    finally:
        # Cleanup
        if service:
            service.stop_service()
        
        # Remove PID file
        if args.daemon and args.pid_file and os.path.exists(args.pid_file):
            try:
                os.remove(args.pid_file)
                logger.info(f"PID file removed: {args.pid_file}")
            except Exception as e:
                logger.error(f"Failed to remove PID file: {e}")
        
        logger.info("Mail Webhooks Monitor Service stopped")

if __name__ == "__main__":
    main()
