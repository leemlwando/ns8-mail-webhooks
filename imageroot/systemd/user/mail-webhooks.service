#
# Mail Webhooks API service
#
[Unit]
Description=Mail Webhooks API server
After=network.target

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
EnvironmentFile=%S/state/environment
WorkingDirectory=%h
Restart=always
TimeoutStartSec=120
ExecStartPre=/bin/rm -f %t/mail-webhooks.pid %t/mail-webhooks.ctr-id
ExecStart=/usr/bin/podman run \
    --detach \
    --conmon-pidfile=%t/mail-webhooks.pid \
    --cidfile=%t/mail-webhooks.ctr-id \
    --cgroups=no-conmon \
    --replace --name=%N \
    --publish=127.0.0.1:${TCP_PORT}:8080 \
    --volume=./api:/app:Z \
    --env=MONGODB_URL=${MONGODB_URL} \
    --env=MAIL_SERVER_UUID=${MAIL_SERVER_UUID} \
    --env=WEBHOOKS_COLLECTION=${WEBHOOKS_COLLECTION:-webhooks} \
    --env=EVENTS_COLLECTION=${EVENTS_COLLECTION:-events} \
    --env=SETTINGS_COLLECTION=${SETTINGS_COLLECTION:-settings} \
    --env=TRIGGERS_COLLECTION=${TRIGGERS_COLLECTION:-triggers} \
    --env=LOGS_COLLECTION=${LOGS_COLLECTION:-logs} \
    --workdir=/app \
    python:3.11-slim bash -c "chmod +x /app/entrypoint.sh && /app/entrypoint.sh"
ExecStop=/usr/bin/podman stop --ignore --cidfile %t/mail-webhooks.ctr-id -t 10
ExecStopPost=/usr/bin/podman rm --ignore -f --cidfile %t/mail-webhooks.ctr-id
PIDFile=%t/mail-webhooks.pid
Type=forking

[Install]
WantedBy=default.target
